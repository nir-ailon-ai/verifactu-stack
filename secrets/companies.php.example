<?php
// -----------------------------------------------------------------------------
// Copy this file to secrets/companies.php, chmod 600, and NEVER commit it.
// The container reads it at /secrets/companies.php (read-only mount).
// -----------------------------------------------------------------------------

return [

    // Database — points at the docker-compose 'db' service.
    // The password is read from the environment variable DB_PASS at runtime
    // (fed from MARIADB_PASSWORD in .env), so this file doesn't need to hold it.
    'database' => [
        'host' => getenv('DB_HOST') ?: 'db',
        'port' => (int)(getenv('DB_PORT') ?: 3306),
        'name' => getenv('DB_NAME') ?: 'facturascripts',
        'user' => getenv('DB_USER') ?: 'fsuser',
        'pass' => getenv('DB_PASS') ?: '',
    ],

    // Global SIF (Sistema Informático de Facturación) metadata.
    // AEAT keys the hash chain by (issuer NIF, id, installation_number).
    'sif' => [
        // 2-char identifier for this software. Unique within your own products;
        // AEAT does not check it against a registry.
        'id'                  => 'XX',

        // Free-text human-readable name.
        'name'                => 'My SIF',

        // Bump when you ship code changes.
        'version'             => '0.1.0',

        // Identifies this specific deployment. Bump to reset the chain at AEAT
        // (e.g. after restoring from backup or migrating to a new host).
        'installation_number' => '0001',

        // Default target for the AEAT submitter when --env is not passed.
        // 'preproduccion' (sandbox) or 'produccion' (LIVE, real fiscal effect).
        'environment'         => 'preproduccion',
    ],

    // Per-invoice-series environment allowlist.
    // Series listed here can only submit to the environments named.
    // Series NOT listed default to allowing both environments.
    //
    // Use this to keep test invoices out of producción. The convention:
    //   T = pruebas (test-only)
    //   A = real invoices
    //   R = rectificativas
    //   S = simplificadas
    'series' => [
        'T' => ['preproduccion'],
    ],

    // Per-empresa identity + cert. Key is the NIF as stored in FS's
    // empresas.cifnif column. Cert files live under /secrets/ (read-only mount).
    'empresas' => [

        // Example: an SL.
        'B00000000' => [
            'name'      => 'EMPRESA EJEMPLO SL',
            'cert_path' => '/secrets/empresa-cert.p12',
            'cert_pass' => 'CHANGE_ME',
        ],

        // Example: an autónomo (personal NIF).
        '00000000X' => [
            'name'      => 'NOMBRE APELLIDOS',
            'cert_path' => '/secrets/autonomo-cert.p12',
            'cert_pass' => 'CHANGE_ME',
        ],

    ],
];
